#!/usr/bin/env python3
# genesi-ai-tray — standalone system-tray applet for Genesi AI Mode.
#
# WHY libappindicator (Gtk) AND NOT Qt's QSystemTrayIcon:
#   The rich AI Mode widget (live CPU/RAM/GPU + on/auto/off + "Open Monitor") is a
#   Plasma 6 plasmoid (plasmoid-aimode/), which ONLY loads inside plasmashell. The
#   Hyprland + caelestia-shell session has no Plasma, so this exposes the same UX
#   in a tray applet. It USED to be PyQt6 (QSystemTrayIcon), but Qt 6.11's SNI is
#   broken with the caelestia (Quickshell) bar: it registers the item with the
#   StatusNotifierWatcher but never serves its properties to the host, so the icon
#   never appeared (and the DBus path could crash) — the exact problem that forced
#   genesi-containers-tray onto libappindicator (pkgrel 6). libappindicator apps
#   (Spotify, Discord, the Genesi Containers tray) show fine in the same bar, so
#   this applet now uses libayatana-appindicator (the proven SNI path) too.
#
#   appindicator is menu-only (no arbitrary popup), so the plasmoid's live bars
#   become menu rows refreshed on a timer; the on/auto/off controls + Open Monitor
#   are menu actions driving the same `genesi-ai-mode` CLI / genesi-ai-monitor.
#
# DATA MODEL (single source of truth: the genesi-aid daemon)
#   State : /run/genesi-ai-mode/state.json  (read directly — cheap, no fork)
#   Control: `genesi-ai-mode on|auto|off`   (world-writable runtime flag, no sudo)
#   Monitor: setsid -f /usr/local/bin/genesi-ai-monitor
import json
import signal
import subprocess

import gi

gi.require_version("Gtk", "3.0")
try:
    gi.require_version("AyatanaAppIndicator3", "0.1")
    from gi.repository import AyatanaAppIndicator3 as AppIndicator
except (ValueError, ImportError):       # fall back to the older libappindicator
    gi.require_version("AppIndicator3", "0.1")
    from gi.repository import AppIndicator3 as AppIndicator
from gi.repository import GLib, Gtk

STATE_PATH = "/run/genesi-ai-mode/state.json"
MONITOR = "/usr/local/bin/genesi-ai-monitor"


def read_state():
    """Return the daemon state dict, or {} if the daemon isn't up / mid-write."""
    try:
        with open(STATE_PATH, "r") as fh:
            return json.load(fh)
    except Exception:
        return {}


def set_mode(mode):
    """Flip the AI Mode override via the CLI (on|auto|off)."""
    try:
        subprocess.Popen(
            ["genesi-ai-mode", mode],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except Exception:
        pass


def open_monitor():
    """Launch the standalone Monitor detached (survives this process)."""
    try:
        subprocess.Popen(["setsid", "-f", MONITOR],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        try:
            subprocess.Popen([MONITOR], start_new_session=True,
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except Exception:
            pass


def _item(label, enabled=True, on_activate=None):
    mi = Gtk.MenuItem(label=label)
    mi.set_sensitive(enabled)
    if on_activate:
        mi.connect("activate", lambda _w: on_activate())
    return mi


class Tray:
    def __init__(self):
        # genesi-ai-monitor icon is shipped into hicolor by this package, so it
        # resolves in any icon theme (hicolor is the universal fallback).
        self.ind = AppIndicator.Indicator.new(
            "genesi-ai-tray", "genesi-ai-monitor",
            AppIndicator.IndicatorCategory.APPLICATION_STATUS)
        self.ind.set_status(AppIndicator.IndicatorStatus.ACTIVE)
        self.ind.set_title("Genesi AI Mode")
        self.rebuild()
        # dbusmenu has no reliable "about to show" via the host, so refresh the
        # menu (and the live metrics in it) on a light timer.
        GLib.timeout_add_seconds(3, self._tick)

    def _tick(self):
        self.rebuild()
        return True  # keep the timer running

    def rebuild(self):
        s = read_state()
        menu = Gtk.Menu()

        if not s:
            self.ind.set_title("Genesi AI Mode — daemon offline")
            menu.append(_item("AI Mode — daemon offline", False))
            force = None
        else:
            active = bool(s.get("ai_mode_active"))
            force = s.get("force_mode", "auto")
            agg = bool(s.get("aggressive"))
            if active:
                state = ("ON (forced)" if force == "on"
                         else "ON (max)" if agg else "ON (battery-safe)")
            else:
                state = "OFF (forced)" if force == "off" else "OFF"
            self.ind.set_title(f"Genesi AI Mode: {state}")
            menu.append(_item(f"AI Mode: {state}", False))

            m = s.get("metrics", {}) or {}
            cpu = m.get("cpu_percent")
            if isinstance(cpu, (int, float)):
                menu.append(_item(f"CPU: {cpu:.0f}%", False))
            ru, rt = m.get("ram_used_mb"), m.get("ram_total_mb")
            if ru is not None and rt:
                menu.append(_item(f"RAM: {ru} / {rt} MB", False))
            for g in (m.get("gpus") or []):
                util = g.get("util")
                vendor = g.get("vendor", "?")
                menu.append(_item(
                    f"GPU {vendor}: {util}%" if util is not None else f"GPU {vendor}",
                    False))
            ollama = s.get("ollama") or []
            tps = s.get("tokens_per_second")
            model = "Local model loaded" if ollama else "No model loaded"
            if tps:
                model += f" · {tps} tok/s"
            menu.append(_item(model, False))

        menu.append(Gtk.SeparatorMenuItem())
        # active force-mode marked with a dot
        menu.append(_item(("● " if force == "on" else "   ") + "Force ON",
                          on_activate=lambda: set_mode("on")))
        menu.append(_item(("● " if force == "auto" else "   ") + "Auto",
                          on_activate=lambda: set_mode("auto")))
        menu.append(_item(("● " if force == "off" else "   ") + "Force OFF",
                          on_activate=lambda: set_mode("off")))
        menu.append(Gtk.SeparatorMenuItem())
        menu.append(_item("Open AI Mode Monitor", on_activate=open_monitor))
        menu.append(Gtk.SeparatorMenuItem())
        menu.append(_item("Quit", on_activate=Gtk.main_quit))
        menu.show_all()
        self.ind.set_menu(menu)


def main():
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    Tray()
    Gtk.main()


if __name__ == "__main__":
    main()
