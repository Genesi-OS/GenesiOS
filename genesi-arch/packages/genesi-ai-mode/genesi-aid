#!/usr/bin/env python3
"""
Genesi AI Daemon (genesi-aid)

Detects local-AI inference processes and applies reversible system
optimizations while they run. When the AI workload stops (and no manual
override is set) every tweak is restored to the value it had before.

Manual control (user -> daemon) and status (daemon -> user) flow through a
world-readable runtime directory created by tmpfiles.d, so the daemon can keep
`PrivateTmp=true` hardening:

    /run/genesi-ai-mode/force      user-written: "on" | "off" | absent(=auto)
    /run/genesi-ai-mode/state.json daemon-written status (read by the widget/CLI)

The pre-change values are stashed in a root-only file under /run so a daemon
restart (same boot) restores correctly instead of "restoring" the already
modified value. /run is a tmpfs, so a real reboot starts clean.
"""

import os
import re
import sys
import json
import time
import logging
import tempfile

import psutil

# ── Paths ────────────────────────────────────────────────────────────────────
RUN_DIR     = "/run/genesi-ai-mode"          # 0777, created by tmpfiles.d
FORCE_FILE  = os.path.join(RUN_DIR, "force")  # user-writable control file
STATE_FILE  = os.path.join(RUN_DIR, "state.json")
ORIGINALS_FILE = "/run/genesi-aid-originals.json"  # root-only (0600)

GOVERNOR_GLOB = "/sys/devices/system/cpu/cpu{}/cpufreq/scaling_governor"
SWAPPINESS    = "/proc/sys/vm/swappiness"
THP_ENABLED   = "/sys/kernel/mm/transparent_hugepage/enabled"

POLL_SECONDS  = 5
AI_NICE       = -5

# AI process patterns (matched against process name and full cmdline).
AI_PROCESSES = [
    "ollama",
    "llama-server",
    "llama-cli",
    "llama.cpp",
    "vllm",
    "localai",
    "text-generation-webui",
    "koboldcpp",
    "oobabooga",
]

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    handlers=[logging.StreamHandler()],   # journal captures stdout/stderr
)
logger = logging.getLogger("genesi-aid")


def _atomic_write(path: str, data: str, mode: int = 0o644):
    """Write a file atomically so readers never see a half-written file."""
    directory = os.path.dirname(path)
    fd, tmp = tempfile.mkstemp(dir=directory, prefix=".tmp-")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(data)
        os.chmod(tmp, mode)
        os.replace(tmp, path)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


class AIOptimizer:
    def __init__(self):
        self.ai_mode_active = False
        self.originals = {}              # {'governor','swappiness','thp'}
        self.ai_processes = []           # list[psutil.Process]
        self._restore_originals_on_start()

    # ── Detection ────────────────────────────────────────────────────────────
    def detect_ai_processes(self):
        found = []
        for proc in psutil.process_iter(["pid", "name", "cmdline"]):
            try:
                name = (proc.info["name"] or "").lower()
                cmdline = " ".join(proc.info["cmdline"] or []).lower()
                for pattern in AI_PROCESSES:
                    if pattern in name or pattern in cmdline:
                        found.append(proc)
                        break
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue
        return found

    def read_force(self):
        """Return 'on', 'off' or None (auto). Only exact values act."""
        try:
            with open(FORCE_FILE) as f:
                value = f.read().strip().lower()
            if value in ("on", "off"):
                return value
        except FileNotFoundError:
            pass
        except OSError as e:
            logger.debug(f"Could not read force file: {e}")
        return None

    # ── Low-level knobs ──────────────────────────────────────────────────────
    def _read_governor(self):
        try:
            with open(GOVERNOR_GLOB.format(0)) as f:
                return f.read().strip()
        except OSError:
            return None

    def _set_governor(self, governor):
        if not governor:
            return
        changed = False
        for cpu in range(psutil.cpu_count() or 0):
            path = GOVERNOR_GLOB.format(cpu)
            try:
                with open(path, "w") as f:
                    f.write(governor)
                changed = True
            except OSError:
                continue  # core offline / governor not settable on this CPU
        if changed:
            logger.info(f"CPU governor set to: {governor}")

    def _read_swappiness(self):
        try:
            with open(SWAPPINESS) as f:
                return int(f.read().strip())
        except (OSError, ValueError):
            return None

    def _set_swappiness(self, value):
        if value is None:
            return
        try:
            with open(SWAPPINESS, "w") as f:
                f.write(str(value))
            logger.info(f"Swappiness set to: {value}")
        except OSError as e:
            logger.error(f"Failed to set swappiness: {e}")

    def _read_thp(self):
        """Current THP mode is the bracketed token: 'always [madvise] never'."""
        try:
            with open(THP_ENABLED) as f:
                data = f.read()
            m = re.search(r"\[(\w+)\]", data)
            return m.group(1) if m else None
        except OSError:
            return None

    def _set_thp(self, value):
        if not value:
            return
        try:
            with open(THP_ENABLED, "w") as f:
                f.write(value)
            logger.info(f"Transparent huge pages set to: {value}")
        except OSError as e:
            logger.error(f"Failed to set THP: {e}")

    # ── Originals persistence (survives daemon restart, not reboot) ───────────
    def _persist_originals(self):
        try:
            _atomic_write(ORIGINALS_FILE, json.dumps(self.originals), mode=0o600)
        except OSError as e:
            logger.error(f"Failed to persist originals: {e}")

    def _clear_originals(self):
        self.originals = {}
        try:
            os.unlink(ORIGINALS_FILE)
        except FileNotFoundError:
            pass
        except OSError as e:
            logger.debug(f"Could not remove originals file: {e}")

    def _restore_originals_on_start(self):
        """If a previous instance left AI Mode active (crash/restart), adopt the
        saved originals and mark ourselves active so the loop can restore them
        cleanly instead of capturing the already-tuned values as 'original'."""
        try:
            with open(ORIGINALS_FILE) as f:
                self.originals = json.load(f)
            self.ai_mode_active = True
            logger.info("Recovered AI Mode state from previous run")
        except FileNotFoundError:
            pass
        except (OSError, ValueError) as e:
            logger.warning(f"Ignoring unreadable originals file: {e}")

    # ── Mode transitions ─────────────────────────────────────────────────────
    def enable_ai_mode(self):
        if self.ai_mode_active:
            return
        logger.info("Enabling AI Mode...")
        self.originals = {
            "governor": self._read_governor(),
            "swappiness": self._read_swappiness(),
            "thp": self._read_thp(),
        }
        self._persist_originals()

        self._set_governor("performance")
        self._set_swappiness(10)
        self._set_thp("always")

        self.ai_mode_active = True
        logger.info("AI Mode enabled")

    def disable_ai_mode(self):
        if not self.ai_mode_active:
            return
        logger.info("Disabling AI Mode...")

        self._set_governor(self.originals.get("governor"))
        self._set_swappiness(self.originals.get("swappiness"))
        self._set_thp(self.originals.get("thp"))

        # Drop the priority bump on any AI process still running.
        for proc in self.ai_processes:
            try:
                proc.nice(0)
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue

        self.ai_mode_active = False
        self._clear_originals()
        logger.info("AI Mode disabled")

    def prioritize_ai_processes(self):
        """Give AI processes more CPU time. Idempotent, so processes that spawn
        after AI Mode is already active still get prioritized.

        We intentionally do NOT pin to a subset of cores: CPU inference scales
        with ALL cores, so affinity-limiting it would hurt the main use case.
        """
        for proc in self.ai_processes:
            try:
                if proc.nice() != AI_NICE:
                    proc.nice(AI_NICE)
                    logger.info(f"Prioritized {proc.name()} (PID {proc.pid})")
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue

    # ── State export for the widget / CLI ────────────────────────────────────
    def _save_state(self, force_mode):
        procs = []
        for p in self.ai_processes:
            try:
                procs.append({"pid": p.pid, "name": p.name()})
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue
        state = {
            "ai_mode_active": self.ai_mode_active,
            "force_mode": force_mode or "auto",
            "ai_processes": procs,
            "timestamp": time.time(),
        }
        try:
            _atomic_write(STATE_FILE, json.dumps(state))
        except OSError as e:
            logger.debug(f"Could not write state file: {e}")

    # ── Main loop ────────────────────────────────────────────────────────────
    def run(self):
        logger.info("Genesi AI Daemon started")
        while True:
            try:
                force = self.read_force()
                self.ai_processes = self.detect_ai_processes()

                if force == "off":
                    want_active = False
                elif force == "on":
                    want_active = True
                else:
                    want_active = bool(self.ai_processes)

                if want_active and not self.ai_mode_active:
                    self.enable_ai_mode()
                elif not want_active and self.ai_mode_active:
                    self.disable_ai_mode()

                if self.ai_mode_active:
                    self.prioritize_ai_processes()

                self._save_state(force)
                time.sleep(POLL_SECONDS)
            except KeyboardInterrupt:
                logger.info("Shutting down...")
                if self.ai_mode_active:
                    self.disable_ai_mode()
                break
            except Exception as e:
                logger.error(f"Error in main loop: {e}")
                time.sleep(POLL_SECONDS)


def main():
    if os.geteuid() != 0:
        print("Error: genesi-aid must run as root", file=sys.stderr)
        sys.exit(1)
    os.makedirs(RUN_DIR, exist_ok=True)
    AIOptimizer().run()


if __name__ == "__main__":
    main()
