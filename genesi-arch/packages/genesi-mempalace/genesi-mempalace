#!/usr/bin/env python3
"""
Genesi MemPalace integration — local-first long-term memory for the on-device AI.

MemPalace (https://github.com/MemPalace/mempalace, PyPI `mempalace`, MIT) stores
conversations and project context verbatim and retrieves them with local
semantic search — zero cloud, nothing leaves the machine. It is a PER-USER tool:
the "palace" lives in $HOME, its MCP server runs on demand over stdio, and its
"background service" role is really a periodic indexer. This launcher wraps that
for Genesi so the rest of the system (the Monitor, the prompt-cache bridge, MCP
clients) has one stable entry point.

  genesi-mempalace watch     the background service loop: periodically mine the
                             configured project paths + sweep local-AI transcript
                             dirs, then publish state for the Monitor (low prio)
  genesi-mempalace mine      run a single index pass now
  genesi-mempalace sweep     run a single per-message transcript sweep now
  genesi-mempalace status    print palace stats as JSON (and refresh the state file)
  genesi-mempalace mcp       exec the MemPalace MCP server over stdio (what an
                             mcp.json entry should point at — guarantees the
                             isolated env + palace path are set)
  genesi-mempalace install   provision the `mempalace` CLI for the current user
                             (uv tool install, the upstream-recommended way)
  genesi-mempalace doctor    check that everything is wired up

Config: /etc/genesi-mempalace/genesi-mempalace.conf (system defaults) overlaid by
~/.config/genesi-mempalace/config.conf (per-user). `key = value`, '#' comments.
Everything is opt-in and degrades to a no-op if `mempalace` isn't installed yet
— the service never crashes, it just logs a hint.

IMPORTANT (supply chain): MemPalace's ONLY official sources are the GitHub repo,
the PyPI package `mempalace`, and mempalaceofficial.com. We provision strictly
from PyPI. Other domains (.tech/.net/…) are impostors that may ship malware.
"""

import os
import sys
import json
import time
import shutil
import hashlib
import logging
import tempfile
import threading
import subprocess
import urllib.request
import urllib.error
import http.server

# ── Paths ─────────────────────────────────────────────────────────────────────
SYS_CONF  = "/etc/genesi-mempalace/genesi-mempalace.conf"
USER_CONF = os.path.expanduser("~/.config/genesi-mempalace/config.conf")

# Per-user runtime state for the Monitor (indexed counts, last sync, health).
# Lives under XDG_RUNTIME_DIR when available (tmpfs, per-user, cleaned on logout),
# else a cache dir. The Monitor reads whichever exists.
def _state_path():
    rt = os.environ.get("XDG_RUNTIME_DIR")
    base = rt if rt and os.path.isdir(rt) else os.path.expanduser("~/.cache/genesi-mempalace")
    os.makedirs(base, exist_ok=True)
    return os.path.join(base, "mempalace-state.json")

# Default palace location (MemPalace's own default is ~/.mempalace). Overridable
# via the MEMPALACE_HOME env / config so power users can relocate it.
def _palace_home():
    return (os.environ.get("MEMPALACE_HOME")
            or _conf().get("palace_home")
            or os.path.expanduser("~/.mempalace"))

WATCH_INTERVAL_DEFAULT = 900   # seconds between background index passes (15 min)

# ── Prompt-cache bridge (roadmap 2.7.1) ───────────────────────────────────────
# A local proxy in front of the Turbo llama-server that (1) injects MemPalace
# memory as a STABLE prefix so the engine's KV cache actually hits, and (2)
# save/restores a per-wing KV slot to disk so reopening a chat skips the prompt
# prefill (cold-start kill). See docs/MEMPALACE-PROMPT-CACHE.md. Opt-in.
BRIDGE_PORT_DEFAULT = 11436          # ollama=11434, Turbo=11435, bridge=11436
TURBO_URL_DEFAULT   = "http://127.0.0.1:11435"
CORE_TTL_DEFAULT    = 300            # seconds a wing's "core memory" is cached
RECALL_K_DEFAULT    = 5              # top-k dynamic snippets per request
# The Turbo server persists slots here (genesi-ai-turbo --slot-save-path). We
# write one file per wing under it; filenames are relative to that dir.
SLOT_DIR_DEFAULT    = os.path.expanduser("~/.cache/genesi-turbo/slots")

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s - genesi-mempalace - %(levelname)s - %(message)s",
    handlers=[logging.StreamHandler()],
)
logger = logging.getLogger("genesi-mempalace")

_CONF_CACHE = None


def _conf():
    """Merged config: system defaults overlaid by the per-user file. Cached."""
    global _CONF_CACHE
    if _CONF_CACHE is not None:
        return _CONF_CACHE
    conf = {}
    for path in (SYS_CONF, USER_CONF):
        try:
            with open(path) as f:
                data = f.read()
        except OSError:
            continue
        for line in data.splitlines():
            line = line.split("#", 1)[0].strip()
            if "=" in line:
                k, v = line.split("=", 1)
                conf[k.strip().lower()] = v.strip()
    _CONF_CACHE = conf
    return conf


def _conf_list(key):
    """A config value that is a list (comma- or newline-separated), expanded for
    '~'. Empty when unset."""
    raw = _conf().get(key, "")
    parts = [p.strip() for p in raw.replace("\n", ",").split(",")]
    return [os.path.expanduser(p) for p in parts if p]


def _conf_int(key, default):
    try:
        return int(_conf().get(key, "").strip())
    except (TypeError, ValueError):
        return default


def _mempalace_bin():
    """The `mempalace` CLI on PATH, or in the user's uv/pipx tool dir, or None."""
    direct = shutil.which("mempalace")
    if direct:
        return direct
    for cand in (os.path.expanduser("~/.local/bin/mempalace"),
                 os.path.expanduser("~/.local/share/uv/tools/mempalace/bin/mempalace")):
        if os.path.exists(cand):
            return cand
    return None


def _run(cmd, timeout=None, check=False):
    """Run a command, capturing output. Returns (rc, stdout). Never hangs the
    service indefinitely unless timeout is None (only used for the MCP exec)."""
    try:
        p = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        if check and p.returncode != 0:
            logger.debug("cmd %r rc=%s: %s", cmd, p.returncode, (p.stderr or "").strip())
        return p.returncode, (p.stdout or "").strip()
    except (subprocess.TimeoutExpired, OSError) as e:
        logger.debug("cmd %r failed: %s", cmd, e)
        return 1, ""


def _atomic_write(path, data):
    d = os.path.dirname(path)
    os.makedirs(d, exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=d, prefix=".tmp-")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(data)
        os.replace(tmp, path)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


# ── palace stats (best-effort, for the Monitor) ───────────────────────────────
def _palace_stats():
    """Cheap, dependency-free snapshot of the palace for the Monitor. We do NOT
    invent `mempalace` subcommands we can't guarantee exist across versions —
    we read the on-disk palace structure (wings/rooms/drawers) and let any real
    `mempalace` stats command, if present, override later."""
    home = _palace_home()
    stats = {"palace_home": home, "exists": os.path.isdir(home),
             "wings": 0, "drawers": 0}
    if not stats["exists"]:
        return stats
    wings = 0
    drawers = 0
    try:
        wings_dir = os.path.join(home, "wings")
        scan_root = wings_dir if os.path.isdir(wings_dir) else home
        for root, dirs, files in os.walk(scan_root):
            depth = root[len(scan_root):].count(os.sep)
            if depth == 0:
                wings += sum(1 for d in dirs if not d.startswith("."))
            drawers += sum(1 for f in files if f.endswith((".json", ".md", ".txt")))
    except OSError:
        pass
    stats["wings"] = wings
    stats["drawers"] = drawers
    return stats


def write_state(last_sync=None, last_action=None, error=None):
    """Publish per-user state for the Monitor card."""
    binp = _mempalace_bin()
    state = {
        "installed": binp is not None,
        "binary": binp,
        "version": _mempalace_version(binp) if binp else None,
        "last_sync": last_sync,
        "last_action": last_action,
        "error": error,
        "stats": _palace_stats(),
        "timestamp": time.time(),
    }
    try:
        _atomic_write(_state_path(), json.dumps(state))
    except OSError as e:
        logger.debug("state write: %s", e)
    return state


def _mempalace_version(binp):
    rc, out = _run([binp, "--version"], timeout=10)
    return out.split()[-1] if rc == 0 and out else None


# ── actions ────────────────────────────────────────────────────────────────────
def cmd_mine():
    """Index the configured project paths into the palace (one pass)."""
    binp = _mempalace_bin()
    if not binp:
        logger.warning("mempalace not installed — run `genesi-mempalace install`")
        write_state(error="not-installed")
        return 1
    paths = _conf_list("index_paths")
    if not paths:
        logger.info("no index_paths configured — nothing to mine")
        write_state(last_action="mine:noop")
        return 0
    backend = _conf().get("backend", "").strip()
    rc_all = 0
    for p in paths:
        if not os.path.isdir(p):
            logger.info("skip missing path: %s", p)
            continue
        cmd = [binp, "mine", p]
        if backend:
            cmd += ["--backend", backend]
        logger.info("mining %s ...", p)
        rc, _ = _run(cmd, timeout=_conf_int("mine_timeout", 3600))
        rc_all = rc_all or rc
    write_state(last_sync=time.time(), last_action="mine",
                error=None if rc_all == 0 else "mine-failed")
    return rc_all


def cmd_sweep():
    """Per-message sweep of local-AI transcript dirs (idempotent, resume-safe)."""
    binp = _mempalace_bin()
    if not binp:
        logger.warning("mempalace not installed — run `genesi-mempalace install`")
        write_state(error="not-installed")
        return 1
    dirs = _conf_list("transcript_dirs")
    if not dirs:
        logger.info("no transcript_dirs configured — skipping sweep")
        return 0
    rc_all = 0
    for d in dirs:
        if not os.path.isdir(d):
            continue
        logger.info("sweeping %s ...", d)
        rc, _ = _run([binp, "sweep", d], timeout=_conf_int("sweep_timeout", 1800))
        rc_all = rc_all or rc
    write_state(last_sync=time.time(), last_action="sweep",
                error=None if rc_all == 0 else "sweep-failed")
    return rc_all


def cmd_status():
    """Print palace stats as JSON and refresh the Monitor state file."""
    print(json.dumps(write_state(), indent=2))
    return 0


def cmd_mcp():
    """Exec the MemPalace MCP server over stdio. This is what an mcp.json entry
    should invoke (`genesi-mempalace mcp`) so the isolated env + palace path are
    guaranteed set. Replaces this process so JSON-RPC on stdin/stdout is clean."""
    binp = _mempalace_bin()
    if not binp:
        sys.stderr.write("mempalace not installed — run `genesi-mempalace install`\n")
        return 1
    env = dict(os.environ)
    env.setdefault("MEMPALACE_HOME", _palace_home())
    # The bare `mempalace` command runs the MCP server over stdio (per upstream).
    os.execve(binp, [binp], env)
    return 0  # unreachable


def cmd_install():
    """Provision the `mempalace` CLI for the CURRENT user via uv tool install —
    the isolated env upstream recommends (avoids PEP 668 / dep conflicts). We
    deliberately install per-user (the palace lives in $HOME), never system-wide
    as root, and strictly from PyPI (the only official source besides GitHub)."""
    if _mempalace_bin():
        logger.info("mempalace already installed at %s", _mempalace_bin())
        return 0
    extras = _conf().get("install_extras", "").strip()  # e.g. "gpu" or "extract,spellcheck"
    pkg = f"mempalace[{extras}]" if extras else "mempalace"
    if shutil.which("uv"):
        logger.info(":: installing %s via uv tool ...", pkg)
        rc, _ = _run(["uv", "tool", "install", pkg])
        if rc == 0:
            logger.info("done. The `mempalace` CLI is now on your PATH.")
            return 0
    if shutil.which("pipx"):
        logger.info(":: uv unavailable; trying pipx ...")
        rc, _ = _run(["pipx", "install", pkg])
        if rc == 0:
            return 0
    logger.error("could not install mempalace. Install `uv` (recommended) or "
                 "`pipx`, then run: uv tool install %s", pkg)
    return 1


def cmd_doctor():
    binp = _mempalace_bin()
    ok = True
    print("genesi-mempalace doctor")
    print(f"  mempalace CLI : {binp or 'NOT FOUND — run `genesi-mempalace install`'}")
    if not binp:
        ok = False
    print(f"  palace home   : {_palace_home()} "
          f"({'exists' if os.path.isdir(_palace_home()) else 'not created yet'})")
    paths = _conf_list("index_paths") or ["(none configured)"]
    print(f"  index paths   : {', '.join(paths)}")
    tdirs = _conf_list("transcript_dirs") or ["(none configured)"]
    print(f"  transcripts   : {', '.join(tdirs)}")
    print(f"  uv / pipx     : uv={'yes' if shutil.which('uv') else 'no'} "
          f"pipx={'yes' if shutil.which('pipx') else 'no'}")
    up = _turbo_url()
    print(f"  Turbo upstream: {up} ({'reachable' if _turbo_health(up) else 'DOWN'})")
    print(f"  bridge port   : {_conf_int('bridge_port', BRIDGE_PORT_DEFAULT)}")
    return 0 if ok else 1


def cmd_watch():
    """Background service loop. Low priority by design — memory indexing must
    never compete with the foreground AI it serves. Runs an index pass + sweep
    every WATCH_INTERVAL, refreshing the Monitor state in between."""
    # Be a good citizen: nice + idle IO so mining never steals cycles from
    # active inference (AI Mode is about performance, after all).
    try:
        os.nice(10)
    except OSError:
        pass
    interval = _conf_int("watch_interval", WATCH_INTERVAL_DEFAULT)
    logger.info("MemPalace indexer started (interval=%ss, palace=%s)",
                interval, _palace_home())
    if not _mempalace_bin():
        logger.warning("mempalace not installed yet — the loop will keep checking; "
                       "run `genesi-mempalace install` to provision it.")
    while True:
        try:
            if _mempalace_bin():
                cmd_mine()
                cmd_sweep()
            else:
                write_state(error="not-installed")
        except Exception as e:                       # never let the loop die
            logger.error("watch pass error: %s", e)
            write_state(error=str(e))
        time.sleep(interval)


# ── prompt-cache bridge (roadmap 2.7.1) ─────────────────────────────────────────
def _turbo_url():
    return (_conf().get("turbo_url") or TURBO_URL_DEFAULT).rstrip("/")


def _turbo_health(url=None):
    url = url or _turbo_url()
    try:
        with urllib.request.urlopen(url + "/health", timeout=2) as r:
            return json.loads(r.read()).get("status") == "ok"
    except Exception:
        return False


def _mp_try(args_variants, timeout=20):
    """Run `mempalace` trying each argv variant until one succeeds; return its
    stdout, or "" if none worked / mempalace is absent. Keeps the bridge robust
    to CLI-flag drift across mempalace versions (e.g. a `--wing` a given release
    may not accept) — it simply falls back to a broader query."""
    binp = _mempalace_bin()
    if not binp:
        return ""
    for args in args_variants:
        rc, out = _run([binp] + args, timeout=timeout)
        if rc == 0 and out.strip():
            return out.strip()
    return ""


def _mp_core(wing):
    """The STABLE 'core memory' for a wing — the cacheable prefix. Uses
    `mempalace wake-up` (upstream's 'load context for a new session'), scoped to
    the wing when supported. Deterministic across turns => the engine reuses its
    KV. Empty when mempalace/the wing has nothing yet."""
    return _mp_try([["wake-up", "--wing", wing], ["wake-up"]])


def _mp_recall(query, wing, k):
    """Small, DYNAMIC top-k recall for THIS message — placed AFTER the stable
    prefix so a changing result set only invalidates a few hundred tokens."""
    if not query.strip():
        return ""
    return _mp_try([
        ["search", query, "--wing", wing, "--top", str(k)],
        ["search", query, "--wing", wing],
        ["search", query],
    ])


# Per-process cache of each wing's core memory: {wing: (text, hash, fetched_at)}.
_CORE_CACHE = {}
_CORE_LOCK = threading.Lock()


def _wing_core(wing):
    """Cached core memory + content hash. Refreshes past core_ttl. When the hash
    changes, the wing's KV slot is stale and gets invalidated so the next turn
    rebuilds + re-saves it."""
    ttl = _conf_int("core_ttl", CORE_TTL_DEFAULT)
    now = time.time()
    with _CORE_LOCK:
        cached = _CORE_CACHE.get(wing)
        if cached and now - cached[2] < ttl:
            return cached[0], cached[1]
    text = _mp_core(wing)
    h = hashlib.sha256(text.encode("utf-8", "replace")).hexdigest()[:16]
    with _CORE_LOCK:
        prev = _CORE_CACHE.get(wing)
        _CORE_CACHE[wing] = (text, h, now)
    if prev and prev[1] != h:
        _slot_invalidate(wing)        # core changed => persisted KV is stale
    return text, h


def _slot_dir():
    d = (os.environ.get("GENESI_TURBO_SLOT_PATH") or _conf().get("slot_dir")
         or SLOT_DIR_DEFAULT)
    return os.path.expanduser(d)


def _slot_file(wing):
    safe = "".join(c if c.isalnum() or c in "-_" else "_" for c in wing) or "default"
    return f"wing-{safe}.bin"


def _slot_call(action, wing):
    """POST /slots/0?action=save|restore with the wing's filename. Best-effort:
    llama-server exposes this only when started with --slot-save-path (Turbo does
    by default), so failure just means 'no persistent cache this run'. We use
    slot 0 — fine for one foreground conversation; concurrent wings would share
    the slot (documented limitation)."""
    if _conf().get("bridge_slots", "on").lower() in ("off", "0", "false", "no"):
        return False
    url = f"{_turbo_url()}/slots/0?action={action}"
    body = json.dumps({"filename": _slot_file(wing)}).encode()
    req = urllib.request.Request(url, data=body,
                                 headers={"Content-Type": "application/json"})
    try:
        with urllib.request.urlopen(req, timeout=10) as r:
            r.read()
        return True
    except Exception as e:
        logger.debug("slot %s(%s): %s", action, wing, e)
        return False


def _slot_invalidate(wing):
    try:
        os.unlink(os.path.join(_slot_dir(), _slot_file(wing)))
        logger.info("invalidated stale KV slot for wing %s", wing)
    except OSError:
        pass


def _build_messages(messages, wing):
    """Two-tier injection (see docs/MEMPALACE-PROMPT-CACHE.md):
      [1] stable core-memory prefix -> a system message, identical across turns
      [2] small dynamic recall      -> a system message for THIS user turn
      [3] the original conversation -> unchanged
    Recall/core are skipped silently when empty."""
    recall_on = _conf().get("bridge_recall", "on").lower() not in ("off", "0", "false", "no")
    core, _ = _wing_core(wing)
    last_user = ""
    for m in reversed(messages):
        if m.get("role") == "user":
            last_user = m.get("content") or ""
            break
    out = []
    if core:
        out.append({"role": "system",
                    "content": "## Long-term memory (MemPalace)\n" + core})
    if recall_on:
        snip = _mp_recall(last_user, wing, _conf_int("recall_k", RECALL_K_DEFAULT))
        if snip:
            out.append({"role": "system",
                        "content": "## Relevant recalled context\n" + snip})
    out.extend(messages)
    return out


def _wing_of(req_headers, body):
    """Resolve the wing (project/conversation scope) from an explicit header or
    body field, else 'default'. Clients set this per chat."""
    w = (req_headers.get("X-Genesi-Wing") or body.get("genesi_wing")
         or _conf().get("default_wing") or "default")
    return str(w).strip() or "default"


def _make_handler():
    bridge = sys.modules[__name__]

    class Handler(http.server.BaseHTTPRequestHandler):
        protocol_version = "HTTP/1.1"

        def log_message(self, *a):
            return

        def _send_upstream(self, method, path, data):
            url = bridge._turbo_url() + path
            req = urllib.request.Request(
                url, data=data, headers={"Content-Type": "application/json"},
                method=method)
            return urllib.request.urlopen(req, timeout=600)

        def _relay(self, upstream):
            """Stream the upstream response back verbatim (SSE + JSON both work)."""
            self.send_response(upstream.status)
            for k, v in upstream.getheaders():
                if k.lower() in ("transfer-encoding", "connection", "content-length"):
                    continue
                self.send_header(k, v)
            self.send_header("Connection", "close")
            self.end_headers()
            while True:
                chunk = upstream.read(8192)
                if not chunk:
                    break
                try:
                    self.wfile.write(chunk)
                    self.wfile.flush()
                except (BrokenPipeError, ConnectionResetError):
                    break

        def _read_body(self):
            n = int(self.headers.get("Content-Length") or 0)
            return self.rfile.read(n) if n else b""

        def do_GET(self):
            try:
                self._relay(self._send_upstream("GET", self.path, None))
            except Exception as e:
                self.send_error(502, f"upstream error: {e}")

        def do_POST(self):
            raw = self._read_body()
            if self.path.split("?")[0] != "/v1/chat/completions":
                try:                         # passthrough everything else unchanged
                    self._relay(self._send_upstream("POST", self.path, raw))
                except Exception as e:
                    self.send_error(502, f"upstream error: {e}")
                return
            try:
                body = json.loads(raw or b"{}")
            except ValueError:
                self.send_error(400, "invalid JSON")
                return
            wing = bridge._wing_of(self.headers, body)
            try:
                body["messages"] = bridge._build_messages(body.get("messages", []), wing)
            except Exception as e:
                logger.debug("memory injection skipped (%s)", e)   # never block a chat
            body["cache_prompt"] = True       # let llama-server reuse prefix KV
            bridge._slot_call("restore", wing)
            try:
                up = self._send_upstream("POST", "/v1/chat/completions",
                                         json.dumps(body).encode())
                self._relay(up)
            except Exception as e:
                self.send_error(502, f"upstream error: {e}")
                return
            bridge._slot_call("save", wing)

    return Handler


def cmd_bridge():
    """Run the MemPalace prompt-cache bridge in front of the Turbo server.
    Additive + opt-in: it only injects a stable memory prefix and manages a
    per-wing KV slot. Bypass it by pointing the client straight at Turbo
    (:11435) — nothing changes."""
    port = _conf_int("bridge_port", BRIDGE_PORT_DEFAULT)
    if not _turbo_health():
        logger.warning("Turbo upstream (%s) is DOWN — start it from the AI Mode "
                       "Monitor (Turbo) or `genesi-ai-turbo serve <model>`. The "
                       "bridge starts anyway and proxies once it's up.", _turbo_url())
    if not _mempalace_bin():
        logger.warning("mempalace not installed — running as a plain KV-slot proxy "
                       "(no memory injection) until `genesi-mempalace install`.")
    httpd = http.server.ThreadingHTTPServer(("127.0.0.1", port), _make_handler())
    logger.info("MemPalace bridge on http://127.0.0.1:%d  ->  %s (slots=%s, recall=%s)",
                port, _turbo_url(), _conf().get("bridge_slots", "on"),
                _conf().get("bridge_recall", "on"))
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        logger.info("bridge shutting down")
        httpd.shutdown()
    return 0


COMMANDS = {
    "watch": cmd_watch, "mine": cmd_mine, "sweep": cmd_sweep,
    "status": cmd_status, "mcp": cmd_mcp, "install": cmd_install,
    "doctor": cmd_doctor, "bridge": cmd_bridge,
}


def main():
    cmd = sys.argv[1] if len(sys.argv) > 1 else "status"
    fn = COMMANDS.get(cmd)
    if not fn:
        sys.stderr.write(__doc__)
        return 2
    return fn() or 0


if __name__ == "__main__":
    sys.exit(main())
