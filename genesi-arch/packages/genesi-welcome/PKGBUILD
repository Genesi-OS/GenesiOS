# Maintainer: Genesi OS Team
pkgname=genesi-welcome
pkgver=1.0.0
# 2026-06-01: bumped 1 -> 2. The installed system kept showing KDE's own
# "Welcome Center" (plasma-welcome, the Konqi mascot screen) because the
# `plasma` meta-package pulls plasma-welcome and nothing removed it — the
# Calamares write-branding disable targeted /etc/xdg/autostart/
# org.kde.plasma.welcome.desktop, which doesn't exist (plasma-welcome
# autostarts via its own mechanism). Conflicting+replacing+providing
# plasma-welcome makes pacman drop it and satisfy the meta dependency with
# genesi-welcome, so only the Genesi welcome shows.
# 2026-06-03: bumped 2 -> 3. The "Modo IA" button was a dead stub (`pass`);
# now it launches the AI Mode Monitor (genesi-ai-monitor), falling back to the
# CLI status in a terminal.
# 2026-06-16: bumped 3 -> 4. CachyOS-Hello-style rework: the SAME app now
# detects live-ISO vs installed (only the live medium shows "Install Genesi
# OS"), adds Documentation/Support/Project link sections, a language selector,
# a "launch at start" toggle, an "Install Apps" shortcut, and a Maintenance
# page (update, reinstall all, reset keyrings, pacman-key --init, clear db lock,
# clean cache, remove orphans, gaming bundle, Snapper, mirrors, DNS, SpoofDPI,
# service toggles) plus a live-ISO "repair installed system" (chroot) helper.
pkgrel=4
pkgdesc="Welcome application for Genesi OS"
arch=('any')
url="https://github.com/zFreshy/GenesiOS"
license=('GPL3')
depends=('python' 'python-pyqt5')
conflicts=('cachyos-hello' 'plasma-welcome')
provides=('cachyos-hello' 'plasma-welcome')
replaces=('plasma-welcome')
source=('genesi-welcome.py'
        'genesi-welcome.desktop')
sha256sums=('SKIP'
            'SKIP')

package() {
    install -Dm755 genesi-welcome.py "$pkgdir/usr/bin/genesi-welcome"
    install -Dm644 genesi-welcome.desktop "$pkgdir/usr/share/applications/genesi-welcome.desktop"
    install -Dm644 genesi-welcome.desktop "$pkgdir/etc/skel/Desktop/genesi-welcome.desktop"
    
    # Auto-start for live ISO
    install -Dm644 genesi-welcome.desktop "$pkgdir/etc/xdg/autostart/genesi-welcome.desktop"
}
