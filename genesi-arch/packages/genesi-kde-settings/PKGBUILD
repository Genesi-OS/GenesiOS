# Maintainer: Genesi OS Team
# Based on CachyOS KDE Settings

_gitname=genesi-pkgbuilds
pkgname=genesi-kde-settings
pkgdesc='Genesi OS KDE Plasma Settings with Glassmorphism'
pkgver=4.9
pkgrel=6
arch=('any')
url="https://github.com/zFreshy/genesi-pkgbuilds"
license=(GPL-1.0-only)
depends=('ttf-fantasque-nerd'
    'noto-fonts'
    'ttf-fira-sans'
    'capitaine-cursors'
)
makedepends=('coreutils' 'git')
provides=('cachyos-desktop-settings' 'cachyos-kde-settings')
conflicts=('cachyos-desktop-settings' 'cachyos-kde-settings')
source=("git+https://github.com/zFreshy/genesi-pkgbuilds.git")
sha512sums=('SKIP')

package() {
    # Get the kde-settings from our repo
    local _srcdir="${srcdir}/${_gitname}/cachyos-kde-settings"
    
    # Download the tarball if the directory structure doesn't exist
    if [ ! -d "${_srcdir}/cachyos-kde-settings-4.9" ]; then
        cd "${_srcdir}"
        curl -L "https://github.com/cachyos/cachyos-kde-settings/archive/4.9.tar.gz" -o cachyos-kde-settings-4.9.tar.gz
        tar xzf cachyos-kde-settings-4.9.tar.gz
    fi
    
    install -d "$pkgdir/etc"
    cp -rf "${_srcdir}/cachyos-kde-settings-4.9/etc" "$pkgdir" 2>/dev/null || true
    install -d "$pkgdir/usr"
    cp -rf "${_srcdir}/cachyos-kde-settings-4.9/usr" "$pkgdir" 2>/dev/null || true

    # Replace all CachyOS branding with Genesi OS
    find "$pkgdir" -type f -exec sed -i 's/CachyOS/Genesi OS/g' {} + 2>/dev/null || true
    find "$pkgdir" -type f -exec sed -i 's/cachyos/genesi/g' {} + 2>/dev/null || true

    # CRITICAL: strip /etc/skel from this package's payload.
    # genesi-settings (1:1.3.4-16 and later) is the canonical source of
    # /etc/skel/.config/* and ships our Genesi blue palette
    # (#0d2030 / BackgroundNormal=13,32,48,230). cachyos-kde-settings's
    # /etc/skel/.config/kdeglobals carries a green CachyOS palette
    # (BackgroundNormal=4,52,44,200) and, depending on pacstrap order,
    # silently overwrites the genesi-settings version. The 2026-05-22
    # install reproduced this: /etc/skel had our blue, but the user's
    # ~/.config/kdeglobals was created from cachyos's green template
    # during user setup. Removing /etc/skel from this package eliminates
    # the conflict at its source.
    #
    # We keep /usr/share/* (color-schemes, plasma themes, wallpapers,
    # Kvantum presets, etc.) because those don't conflict — they're just
    # additional resources the user can pick from in System Settings.
    rm -rf "$pkgdir/etc/skel" 2>/dev/null || true
    # Some upstream tarballs also drop a /etc/xdg/skel; strip that too
    # for the same reason.
    rm -rf "$pkgdir/etc/xdg/skel" 2>/dev/null || true

    # The two sed lines that used to flip cachyos accent #3daee9 / bg
    # #232629 to a custom green here have been removed in pkgrel=6.
    # The package now contains zero opinion about colors — kdeglobals
    # palette lives entirely in genesi-settings, where it can be tuned
    # without re-rolling this PKGBUILD.
}
