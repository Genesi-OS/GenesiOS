#!/usr/bin/env python3
# genesi-containers-tray — standalone system-tray applet for Genesi Containers.
#
# WHY THIS EXISTS
#   The container panel widget is a Plasma 6 plasmoid (plasmoid/), which only
#   loads inside plasmashell. The Hyprland + caelestia-shell session has no
#   Plasma, so this exposes the same control surface as a StatusNotifierItem (SNI)
#   tray icon — caelestia's bar hosts SNIs, and Qt's QSystemTrayIcon registers as
#   one when a watcher is present. Kept deliberately "simple": the icon's menu is
#   rebuilt live (engine + containers) each time it opens, with start/stop/
#   restart/logs/shell per container — a thin front-end over the same
#   `genesi-containers` CLI the plasmoid drives. Pure PyQt6, no Plasma import, so
#   it runs under a bare Wayland compositor. Works in the KDE tray too, but KDE
#   users get the plasmoid, so this is started only on Hyprland.
import json
import signal
import subprocess
import sys

from PyQt6.QtGui import QCursor, QIcon
from PyQt6.QtWidgets import QApplication, QMenu, QSystemTrayIcon

APP_ID = "genesi-containers-tray"


def cli_json(*args):
    """Run `genesi-containers <args>` and parse its JSON stdout."""
    try:
        out = subprocess.run(
            ["genesi-containers", *args],
            capture_output=True, text=True, timeout=15,
        ).stdout.strip()
        return json.loads(out) if out else {}
    except Exception:
        return {}


def cli_run(*args):
    """Fire a control command (start/stop/restart/logs/shell), detached."""
    try:
        subprocess.Popen(
            ["genesi-containers", *args],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except Exception:
        pass


class Tray:
    def __init__(self, app):
        self.app = app
        icon = QIcon.fromTheme("docker")
        if icon.isNull():
            icon = QIcon.fromTheme("application-x-executable")
        self.tray = QSystemTrayIcon(icon)
        self.tray.setToolTip("Genesi Containers")

        self.menu = QMenu()
        self.menu.aboutToShow.connect(self._rebuild)
        self.tray.setContextMenu(self.menu)
        # left-click also opens the (rebuilt) menu, so it behaves like a button
        self.tray.activated.connect(self._activated)
        self.tray.show()

    def _activated(self, reason):
        if reason == QSystemTrayIcon.ActivationReason.Trigger:
            # tray.geometry() is empty under Wayland, so anchor at the cursor
            # (Hyprland reports it) — the SNI host handles right-click itself.
            self._rebuild()
            self.menu.popup(QCursor.pos())

    def _rebuild(self):
        self.menu.clear()
        data = cli_json("list-json")
        engine = data.get("engine", "none")
        containers = data.get("containers", [])
        error = data.get("error")

        header = self.menu.addAction(f"Engine: {engine}")
        header.setEnabled(False)
        self.menu.addSeparator()

        if engine == "none":
            a = self.menu.addAction("No container engine (install docker or podman)")
            a.setEnabled(False)
        elif error == "permission_denied":
            a = self.menu.addAction("Permission denied — run: sudo usermod -aG docker $USER")
            a.setEnabled(False)
        elif not containers:
            a = self.menu.addAction("No containers")
            a.setEnabled(False)
        else:
            running = sum(1 for c in containers if c.get("running"))
            self.tray.setToolTip(
                f"Genesi Containers — {running}/{len(containers)} running ({engine})")
            for c in containers:
                cid = c.get("id", "")
                name = c.get("name", cid[:12] or "?")
                dot = "🟢" if c.get("running") else "⚪"
                sub = self.menu.addMenu(f"{dot} {name}")
                status = sub.addAction(c.get("status", ""))
                status.setEnabled(False)
                ports = c.get("ports")
                if ports:
                    pa = sub.addAction(ports); pa.setEnabled(False)
                sub.addSeparator()
                if c.get("running"):
                    sub.addAction("Stop").triggered.connect(
                        lambda _=False, i=cid: (cli_run("stop", i)))
                    sub.addAction("Restart").triggered.connect(
                        lambda _=False, i=cid: (cli_run("restart", i)))
                else:
                    sub.addAction("Start").triggered.connect(
                        lambda _=False, i=cid: (cli_run("start", i)))
                sub.addSeparator()
                sub.addAction("Logs").triggered.connect(
                    lambda _=False, i=cid: (cli_run("logs", i)))
                sub.addAction("Shell").triggered.connect(
                    lambda _=False, i=cid: (cli_run("shell", i)))

        self.menu.addSeparator()
        self.menu.addAction("Refresh").triggered.connect(self._rebuild)
        self.menu.addAction("Quit").triggered.connect(self.app.quit)


def main():
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    app = QApplication(sys.argv)
    app.setApplicationName(APP_ID)
    app.setDesktopFileName(APP_ID)
    app.setQuitOnLastWindowClosed(False)
    Tray(app)
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
