#!/usr/bin/env python3
# genesi-containers-tray — standalone system-tray applet for Genesi Containers.
#
# WHY libappindicator (Gtk) AND NOT Qt's QSystemTrayIcon:
#   On Hyprland + caelestia (a Quickshell bar), Qt 6.11's QSystemTrayIcon SNI is
#   broken: it registers the item with the StatusNotifierWatcher but doesn't serve
#   its properties to the host (Quickshell's GetAll never readies the item, and a
#   sibling tray even crashed fatally in the DBus path). Apps that use
#   libappindicator (Spotify, Discord) show fine in the same bar — so this applet
#   uses libayatana-appindicator (the proven SNI implementation) instead.
#
#   It's a thin front-end over the same `genesi-containers` CLI the Plasma widget
#   drives. Menu is rebuilt on a timer (engine + live container list) with
#   start/stop/restart/logs/shell per container. Pure Gtk/gi — no Plasma, no Qt.
import json
import signal
import subprocess

import gi

gi.require_version("Gtk", "3.0")
try:
    gi.require_version("AyatanaAppIndicator3", "0.1")
    from gi.repository import AyatanaAppIndicator3 as AppIndicator
except (ValueError, ImportError):       # fall back to the older libappindicator
    gi.require_version("AppIndicator3", "0.1")
    from gi.repository import AppIndicator3 as AppIndicator
from gi.repository import GLib, Gtk


def cli_json(*args):
    """Run `genesi-containers <args>` and parse its JSON stdout."""
    try:
        out = subprocess.run(
            ["genesi-containers", *args],
            capture_output=True, text=True, timeout=15,
        ).stdout.strip()
        return json.loads(out) if out else {}
    except Exception:
        return {}


def cli_run(*args):
    """Fire a control command (start/stop/restart/logs/shell), detached."""
    try:
        subprocess.Popen(
            ["genesi-containers", *args],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except Exception:
        pass


def _item(label, enabled=True, on_activate=None):
    mi = Gtk.MenuItem(label=label)
    mi.set_sensitive(enabled)
    if on_activate:
        mi.connect("activate", lambda _w: on_activate())
    return mi


class Tray:
    def __init__(self):
        # "genesi-containers" (shipped into hicolor by this package) instead of
        # "docker": the bare "docker" name has no icon under the default theme
        # (Tela-circle) / when docker isn't installed, so the tray rendered a
        # broken-image placeholder. hicolor is the universal fallback, so our
        # named icon resolves everywhere.
        self.ind = AppIndicator.Indicator.new(
            "genesi-containers-tray", "genesi-containers",
            AppIndicator.IndicatorCategory.APPLICATION_STATUS)
        self.ind.set_status(AppIndicator.IndicatorStatus.ACTIVE)
        self.ind.set_title("Genesi Containers")
        self.rebuild()
        # dbusmenu has no reliable "about to show" via the host, so refresh the
        # list on a light timer (the CLI call is cheap).
        GLib.timeout_add_seconds(5, self._tick)

    def _tick(self):
        self.rebuild()
        return True  # keep the timer running

    def rebuild(self):
        data = cli_json("list-json")
        engine = data.get("engine", "none")
        containers = data.get("containers", [])
        error = data.get("error")

        menu = Gtk.Menu()
        menu.append(_item(f"Engine: {engine}", enabled=False))
        menu.append(Gtk.SeparatorMenuItem())

        if engine == "none":
            menu.append(_item("No container engine (install docker or podman)", False))
        elif error == "permission_denied":
            menu.append(_item("Permission denied — sudo usermod -aG docker $USER", False))
        elif not containers:
            menu.append(_item("No containers", False))
        else:
            running = sum(1 for c in containers if c.get("running"))
            self.ind.set_title(
                f"Genesi Containers — {running}/{len(containers)} running ({engine})")
            for c in containers:
                cid = c.get("id", "")
                name = c.get("name", cid[:12] or "?")
                dot = "🟢" if c.get("running") else "⚪"
                sub = Gtk.Menu()
                sub.append(_item(c.get("status", ""), False))
                if c.get("ports"):
                    sub.append(_item(c["ports"], False))
                sub.append(Gtk.SeparatorMenuItem())
                if c.get("running"):
                    sub.append(_item("Stop", on_activate=lambda i=cid: cli_run("stop", i)))
                    sub.append(_item("Restart", on_activate=lambda i=cid: cli_run("restart", i)))
                else:
                    sub.append(_item("Start", on_activate=lambda i=cid: cli_run("start", i)))
                sub.append(Gtk.SeparatorMenuItem())
                sub.append(_item("Logs", on_activate=lambda i=cid: cli_run("logs", i)))
                sub.append(_item("Shell", on_activate=lambda i=cid: cli_run("shell", i)))
                parent = Gtk.MenuItem(label=f"{dot} {name}")
                parent.set_submenu(sub)
                menu.append(parent)

        menu.append(Gtk.SeparatorMenuItem())
        menu.append(_item("Refresh", on_activate=self.rebuild))
        menu.append(_item("Quit", on_activate=Gtk.main_quit))
        menu.show_all()
        self.ind.set_menu(menu)


def main():
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    Tray()
    Gtk.main()


if __name__ == "__main__":
    main()
