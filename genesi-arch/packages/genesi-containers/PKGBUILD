# Maintainer: Genesi OS Team <dev@genesios.org>
#
# Phase 4.3 — Container widget in Plasma. A panel applet that lists running/
# stopped Docker or Podman containers with one-click start/stop/restart, logs,
# a shell, and the mapped ports — engine auto-detected (Docker daemon if up,
# else rootless Podman). The widget is a thin front-end over the
# `genesi-containers` CLI, which is the only thing that talks to the engine.
pkgname=genesi-containers
pkgver=1.0.0
# pkgrel 2: drop the hard plasma-workspace dep (the Hyprland-installs-KDE bug).
# This package is in the always-on genesi-desktop meta, so a HARD plasma-workspace
# dep pulled the whole Plasma shell (=> /usr/bin/plasmashell) onto EVERY install,
# including a Hyprland-only pick. The engine-agnostic `genesi-containers` CLI
# needs no Plasma; only the optional plasmoid does, and it merely sits dormant in
# /usr/share/plasma/plasmoids until a Plasma session loads it. So plasma-workspace
# is now an optdepend (KDE installs already get it via the KDE-Desktop group).
# pkgrel 3: make the widget actually see running containers, and explain itself
# when it can't. The plasmoid runs inside plasmashell, whose session predates
# `usermod -aG docker` — so docker calls hit EACCES and the panel showed "No
# containers" while a terminal saw them fine. The CLI now transparently re-runs
# docker under `sg docker` when the session lacks the group but the user is a
# member (works with no re-login). If the user genuinely isn't a member, it
# emits {"error":"permission_denied"} and the widget shows a "Permission
# denied" placeholder with the usermod fix instead of a misleading empty list.
# pkgrel 4: ship genesi-containers-tray — a standalone SNI system-tray applet so
# the container widget exists OUTSIDE Plasma (the Hyprland + caelestia-shell
# session has no plasmashell, so the plasmoid can't load there). Pure PyQt6 (no
# Plasma import); its menu is rebuilt live (engine + containers) with start/stop/
# restart/logs/shell per container — a thin front-end over the same
# `genesi-containers` CLI the plasmoid drives. Registers as a StatusNotifierItem,
# so it shows in the caelestia bar's tray (and the KDE tray, but KDE keeps the
# plasmoid). Started from the caelestia hyprland.conf via exec-once (Hyprland
# ignores /etc/xdg/autostart). New dep: python-pyqt6 (the tray's toolkit; already
# on every install via genesi-update).
# pkgrel 5: ship genesi-containers-tray.desktop (NoDisplay) matching the tray's
# app_id, so xdg-desktop-portal resolves its app info ("App info not found for
# 'genesi-containers-tray'") and the SNI host can resolve its icon/identity.
# pkgrel 6: rewrite the tray on libappindicator (Gtk) instead of Qt's
# QSystemTrayIcon. Diagnosed on hardware: Qt 6.11's QSystemTrayIcon SNI registers
# the item but doesn't serve its properties to the Quickshell host (the item
# never readies, a sibling even crashed fatally in the DBus path), so it never
# showed in the caelestia bar — while libappindicator apps (Spotify/Discord) show
# fine there. Now uses libayatana-appindicator via gi (the proven SNI path),
# menu-based with the same live engine/containers + start/stop/restart/logs/shell.
# Deps swap python-pyqt6 -> python-gobject + libayatana-appindicator + gtk3.
pkgrel=6
pkgdesc='Plasma 6 widget + tray applet to monitor and control Docker/Podman containers'
arch=('any')
url='https://github.com/Genesi-OS/GenesiOS'
license=('GPL-3.0-or-later')
depends=('python'
         # genesi-containers-tray (standalone libappindicator/Gtk SNI applet —
         # Qt's QSystemTrayIcon is broken with Quickshell on Qt 6.11)
         'python-gobject' 'libayatana-appindicator' 'gtk3')
optdepends=(
    'plasma-workspace: the Plasma 6 container widget (KDE/Plasma session only; pulled automatically by the KDE-Desktop install)'
    'docker: container engine (daemon-based)'
    'podman: container engine (rootless, no daemon)'
    'konsole: open container logs and shells in a terminal'
)
source=()
sha256sums=()

package() {
    # Engine-agnostic CLI the widget drives
    install -Dm755 "${startdir}/genesi-containers" \
        "$pkgdir/usr/local/bin/genesi-containers"

    # Standalone SNI tray applet (the container widget for non-Plasma sessions,
    # i.e. Hyprland + caelestia-shell). Started via exec-once from the caelestia
    # hyprland.conf; works in any StatusNotifierItem host.
    install -Dm755 "${startdir}/genesi-containers-tray" \
        "$pkgdir/usr/local/bin/genesi-containers-tray"
    # .desktop matching the tray's app_id so xdg-desktop-portal can resolve its
    # app info (kills "App info not found for 'genesi-containers-tray'") and the
    # SNI host can read its icon/identity. NoDisplay — it's a background applet.
    install -Dm644 "${startdir}/genesi-containers-tray.desktop" \
        "$pkgdir/usr/share/applications/genesi-containers-tray.desktop"

    # Plasma 6 applet
    install -dm755 "$pkgdir/usr/share/plasma/plasmoids/org.genesi.containers"
    cp -r "${startdir}/plasmoid/"* \
        "$pkgdir/usr/share/plasma/plasmoids/org.genesi.containers/"
}
