#!/usr/bin/env bash
# genesi-containers — thin, engine-agnostic wrapper the Plasma widget drives.
#
# Speaks to whichever container engine is available (Docker preferred, Podman
# fallback) and emits clean JSON for the widget to render. All the privileged
# work stays in the engine; this is just a stable CLI the QML can call through
# Plasma's Executable data source.
set -euo pipefail

# ---- engine detection -------------------------------------------------------
detect_engine() {
    if [ -n "${GENESI_CONTAINER_ENGINE:-}" ] && command -v "${GENESI_CONTAINER_ENGINE}" >/dev/null 2>&1; then
        echo "${GENESI_CONTAINER_ENGINE}"; return 0
    fi
    # Prefer Docker only when its daemon actually answers; otherwise Podman
    # (rootless, no daemon) is the better default on a dev desktop.
    if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
        echo docker; return 0
    fi
    if command -v podman >/dev/null 2>&1; then
        echo podman; return 0
    fi
    if command -v docker >/dev/null 2>&1; then
        echo docker; return 0
    fi
    return 1
}

ENGINE="$(detect_engine || true)"

# ---- group-aware invocation -------------------------------------------------
# Docker's socket is group-owned by `docker`. A user freshly added with
# `usermod -aG docker` is a MEMBER in /etc/group, but a session started BEFORE
# that — e.g. the running plasmashell that hosts this widget — still lacks the
# group until the next login. So the same `docker ps` that works in a terminal
# (which the user re-logged or ran `newgrp docker` in) gets EACCES from the
# widget, and the panel shows "No containers" even though some are running.
# Rather than force a logout, transparently re-run docker under `sg docker`
# whenever the direct call is refused but the user is already a group member —
# `sg` switches the GID using /etc/group membership, no password, no re-login.
SG_DOCKER=""

in_docker_group() {
    [ "$(id -gn 2>/dev/null)" = docker ] && return 0
    id -nG 2>/dev/null | tr ' ' '\n' | grep -qx docker && return 0
    case ",$(getent group docker 2>/dev/null | cut -d: -f4)," in
        *,"$(id -un 2>/dev/null)",*) return 0 ;;
    esac
    return 1
}

if [ "${ENGINE:-}" = docker ] && ! docker info >/dev/null 2>&1 && in_docker_group; then
    SG_DOCKER=1
fi

# Run the engine directly, group-hopping only when needed (SG_DOCKER set).
eng() {
    if [ -n "$SG_DOCKER" ]; then
        sg docker -c "$(printf '%q ' "$ENGINE" "$@")"
    else
        "$ENGINE" "$@"
    fi
}

# Same, but stages an argv array in EARGV for use as a terminal's `-e` payload
# (a launched konsole is also a plasmashell child, so it needs the hop too).
eng_argv() {
    if [ -n "$SG_DOCKER" ]; then
        EARGV=(sg docker -c "$(printf '%q ' "$ENGINE" "$@")")
    else
        EARGV=("$ENGINE" "$@")
    fi
}

# ---- commands ---------------------------------------------------------------
case "${1:-list-json}" in
  engine)
    # Print the active engine (or "none"); used by the widget's empty state.
    echo "${ENGINE:-none}"
    ;;

  list-json)
    if [ -z "${ENGINE:-}" ]; then
        echo '{"engine":"none","containers":[]}'
        exit 0
    fi
    # Pull a tab-delimited table from the engine, then let python turn it into
    # well-formed JSON (hand-rolling JSON in bash is a footgun with names/ports
    # that contain quotes or commas).
    err_tmp="$(mktemp)"
    raw="$(eng ps -a \
        --format '{{.ID}}\t{{.Names}}\t{{.Image}}\t{{.State}}\t{{.Status}}\t{{.Ports}}' \
        2>"$err_tmp" || true)"
    err_out="$(cat "$err_tmp"; rm -f "$err_tmp")"
    if echo "$err_out" | grep -qi "permission denied"; then
        echo '{"engine":"'"$ENGINE"'","containers":[],"error":"permission_denied"}'
        exit 0
    fi
    ENGINE="$ENGINE" python3 - "$raw" <<'PY'
import json, os, sys
raw = sys.argv[1] if len(sys.argv) > 1 else ""
out = []
for line in raw.splitlines():
    if not line.strip():
        continue
    parts = line.split("\t")
    parts += [""] * (6 - len(parts))
    cid, name, image, state, status, ports = parts[:6]
    st = (state or "").lower()
    if not st:  # some docker versions leave State empty; infer from Status
        st = "running" if status.lower().startswith("up") else "exited"
    out.append({
        "id": cid, "name": name, "image": image,
        "state": st, "status": status, "ports": ports,
        "running": st == "running",
    })
out.sort(key=lambda c: (not c["running"], c["name"]))
print(json.dumps({"engine": os.environ.get("ENGINE", "none"), "containers": out}))
PY
    ;;

  start|stop|restart)
    [ -n "${ENGINE:-}" ] || { echo "no container engine" >&2; exit 1; }
    [ -n "${2:-}" ] || { echo "usage: genesi-containers $1 <id>" >&2; exit 2; }
    eng "$1" "$2"
    ;;

  logs)
    [ -n "${ENGINE:-}" ] || { echo "no container engine" >&2; exit 1; }
    [ -n "${2:-}" ] || { echo "usage: genesi-containers logs <id>" >&2; exit 2; }
    # Open the logs in a terminal so it can stream/scroll. Fall back to plain
    # output when no terminal is around (e.g. called non-interactively).
    eng_argv logs -f --tail 200 "$2"
    if command -v konsole >/dev/null 2>&1; then
        exec konsole --hold -e "${EARGV[@]}"
    elif command -v x-terminal-emulator >/dev/null 2>&1; then
        exec x-terminal-emulator -e "${EARGV[@]}"
    else
        eng logs --tail 200 "$2"
    fi
    ;;

  shell)
    [ -n "${ENGINE:-}" ] || { echo "no container engine" >&2; exit 1; }
    [ -n "${2:-}" ] || { echo "usage: genesi-containers shell <id>" >&2; exit 2; }
    eng_argv exec -it "$2" sh -c 'command -v bash >/dev/null && exec bash || exec sh'
    term="konsole -e"; command -v konsole >/dev/null 2>&1 || term="x-terminal-emulator -e"
    exec $term "${EARGV[@]}"
    ;;

  *)
    echo "usage: genesi-containers {engine|list-json|start|stop|restart|logs|shell} [id]" >&2
    exit 2
    ;;
esac
