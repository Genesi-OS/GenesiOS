# Maintainer: Genesi OS Team <dev@genesios.org>
#
# llama.cpp with the VULKAN backend — GPU-accelerated local inference on ANY GPU
# (NVIDIA / AMD / Intel), with no CUDA toolkit needed. Genesi ships this so
# Genesi Turbo (speculative decoding, via `genesi-ai-turbo` -> llama-server)
# works out of the box instead of forcing an AUR source build. Genesi already
# ships the Vulkan ICDs (vulkan-radeon/nouveau/intel), so this lights up on real
# hardware; the CPU fallback (generic, GGML_NATIVE=OFF) keeps it portable.
pkgname=genesi-llama-cpp
pkgver=r0
pkgrel=3
pkgdesc='llama.cpp (Vulkan) — local LLM inference backing Genesi Turbo'
arch=('x86_64')
url='https://github.com/ggml-org/llama.cpp'
license=('MIT')
depends=('vulkan-icd-loader' 'gcc-libs' 'glibc')
makedepends=('git' 'cmake' 'vulkan-headers' 'shaderc' 'glslang'
             'spirv-headers' 'spirv-tools')
provides=('llama.cpp')
conflicts=('llama.cpp' 'llama.cpp-vulkan' 'llama.cpp-cuda' 'llama.cpp-git')
source=("git+https://github.com/ggml-org/llama.cpp.git")
sha256sums=('SKIP')

pkgver() {
    cd llama.cpp
    git describe --tags --abbrev=0 2>/dev/null | sed 's/^b/r/' || echo "r0"
}

build() {
    # The Vulkan backend embeds every shader variant (iq2/iq3/iq4/mxfp4/nvfp4…)
    # into one enormous generated TU and forks a compiler per variant. Full
    # `-j$(nproc)` peaks past the CI runner's RAM → "Cannot allocate memory /
    # Failed to fork process" (2026-06-09, after upstream added the fp4 shaders).
    # Cap parallelism to ~1 job per 6 GB of RAM (min 1) so the peak fits; the CI
    # job also adds swap headroom. Local builds on big machines still scale.
    local mem_gb jobs
    mem_gb=$(free -g | awk '/^Mem:/{print $2}' 2>/dev/null || echo 8)
    jobs=$(( mem_gb / 6 )); [ "$jobs" -lt 1 ] && jobs=1
    [ "$jobs" -gt "$(nproc)" ] && jobs=$(nproc)
    echo "genesi-llama-cpp: building with -j${jobs} (RAM ${mem_gb} GB)"

    # CRITICAL — why this is NOT a plain `GGML_NATIVE=OFF` build:
    #
    # ggml's CMake force-enables GGML_AVX2 / GGML_FMA / GGML_F16C to ON by
    # DEFAULT, independent of GGML_NATIVE. So even with GGML_NATIVE=OFF and the
    # publish pipeline pinning CFLAGS to `-march=x86-64`, the ggml-cpu target
    # still gets `-mavx2 -mfma -mf16c` and the binary executes AVX2 opcodes. On
    # any CPU without AVX2 that's an instant `Illegal instruction (core dumped)`
    # — which is exactly what killed `genesi-ai-turbo` on real hardware (it
    # crashed both while serving AND during the `--list-devices` GPU probe, so
    # Turbo never even detected the GPU and Genesi Code fell back to slow CPU
    # ollama). Pinning the individual GGML_AVX* flags OFF would fix the crash but
    # cripple inference on capable CPUs.
    #
    # The right answer is llama.cpp's own redistributable recipe: build the
    # ggml-cpu backend as MULTIPLE dlopen-able variants (baseline x86-64, sse42,
    # avx, avx2, avx512, …) and let ggml pick the best one the CPU actually
    # supports AT RUNTIME. The main binary + loader stay pure baseline x86-64
    # (run on any x86-64 CPU), while the heavy compute uses the fastest variant
    # available — full speed where supported, never an illegal instruction where
    # not. Needs GGML_BACKEND_DL=ON + GGML_NATIVE=OFF + shared libs.
    cmake -B build -S llama.cpp \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Release \
        -DGGML_VULKAN=ON \
        -DGGML_NATIVE=OFF \
        -DGGML_BACKEND_DL=ON \
        -DGGML_CPU_ALL_VARIANTS=ON \
        -DLLAMA_CURL=OFF \
        -DBUILD_SHARED_LIBS=ON
    cmake --build build --config Release -j"${jobs}"
}

package() {
    DESTDIR="$pkgdir" cmake --install build
    install -Dm644 llama.cpp/LICENSE \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
