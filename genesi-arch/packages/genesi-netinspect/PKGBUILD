# Maintainer: Genesi OS Team <dev@genesios.org>
#
# Phase 4.5 — Network inspection. "Genesi API Inspector": a full HTTP/HTTPS
# interception workbench (the free, scriptable Burp-Suite equivalent on Linux)
# built on mitmproxy/mitmweb — live flow list, intercept + edit a request,
# inspect, and replay/resend (Burp's Repeater). The wrapper routes the desktop
# through it for the session (flips back on exit), and `genesi-netinspect cert`
# trusts the mitmproxy CA system-wide so HTTPS/API traffic actually decrypts.
# Plus a `genesi-proxy on|off|toggle` shortcut and a panel/menu toggle.
# pkgrel 2: rework into the Burp-style API Inspector + cert trust subcommand.
pkgname=genesi-netinspect
pkgver=1.0.0
pkgrel=2
pkgdesc='Genesi API Inspector — Burp-style HTTP/HTTPS interception proxy (mitmproxy)'
arch=('any')
url='https://github.com/zFreshy/GenesiOS'
license=('GPL-3.0-or-later')
depends=('mitmproxy')
optdepends=(
    'konsole: terminal the inspector runs in'
    'kdialog: graphical error when mitmproxy is missing'
    'libnotify: desktop notification on proxy toggle'
)
source=()
sha256sums=()

package() {
    install -Dm755 "${startdir}/genesi-proxy" \
        "$pkgdir/usr/local/bin/genesi-proxy"
    install -Dm755 "${startdir}/genesi-netinspect" \
        "$pkgdir/usr/local/bin/genesi-netinspect"

    install -Dm644 "${startdir}/org.genesi.netinspect.desktop" \
        "$pkgdir/usr/share/applications/org.genesi.netinspect.desktop"
    install -Dm644 "${startdir}/org.genesi.proxy-toggle.desktop" \
        "$pkgdir/usr/share/applications/org.genesi.proxy-toggle.desktop"
}
