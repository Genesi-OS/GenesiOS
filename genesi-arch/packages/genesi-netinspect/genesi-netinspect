#!/usr/bin/env bash
# genesi-netinspect — Genesi API Inspector.
#
# A full HTTP/HTTPS interception workbench (the free, scriptable Burp-Suite
# equivalent on Linux) built on mitmproxy. mitmweb gives you the Burp-style
# workflow: a live flow list, intercept/pause + edit a request before it goes
# out, inspect request/response, and replay/resend (Burp's "Repeater"); Python
# addons cover the "extensions" role.
#
# This wrapper makes it one-click: it routes the desktop through the proxy for
# the session (and flips it back on exit), and can trust mitmproxy's CA system
# wide so HTTPS/API traffic actually decrypts instead of erroring.
#
# Usage:
#   genesi-netinspect            start the native Genesi inspector GUI (Proxy/
#                                Repeater/Intruder/Scanner over mitmproxy)
#   genesi-netinspect gui        same as above, explicit
#   genesi-netinspect web        the classic mitmweb UI (proxy on for the session)
#   genesi-netinspect browser    open a pre-configured Chromium (Burp-style): its
#                                traffic goes through the proxy + trusts our CA,
#                                in an isolated profile — WITHOUT touching the
#                                system proxy. Assumes the engine is already up
#                                (GUI or `web`).
#   genesi-netinspect cert       trust the mitmproxy CA system-wide (HTTPS)
#   genesi-netinspect untrust    remove the trusted CA again
set -euo pipefail

HOST=127.0.0.1
PORT="${GENESI_PROXY_PORT:-8080}"
WEBPORT="${GENESI_MITMWEB_PORT:-8081}"
CA="$HOME/.mitmproxy/mitmproxy-ca-cert.pem"
ANCHOR=/etc/ca-certificates/trust-source/anchors/genesi-mitmproxy.pem
CHROMIUM_BINS=(chromium chromium-browser google-chrome-stable google-chrome \
               brave brave-browser vivaldi-stable microsoft-edge microsoft-edge-stable)

die() {
    command -v kdialog >/dev/null 2>&1 && kdialog --error "$1" || echo "$1" >&2
    exit 1
}

find_chromium() {
    local b
    for b in "${CHROMIUM_BINS[@]}"; do
        command -v "$b" >/dev/null 2>&1 && { echo "$b"; return 0; }
    done
    return 1
}

# Base64(SHA-256(SPKI)) of the mitmproxy CA — for Chromium's per-CA cert
# exception (--ignore-certificate-errors-spki-list). Empty if openssl is missing.
ca_spki() {
    command -v openssl >/dev/null 2>&1 || return 0
    openssl x509 -in "$CA" -noout -pubkey 2>/dev/null \
        | openssl pkey -pubin -outform der 2>/dev/null \
        | openssl dgst -sha256 -binary 2>/dev/null \
        | openssl base64 2>/dev/null
}

command -v mitmweb >/dev/null 2>&1 || \
    die "mitmproxy is not installed. Install it with: sudo pacman -S mitmproxy"

ensure_ca() {
    # mitmproxy generates its CA the first time any of its tools runs. Trigger
    # that headlessly if we don't have a CA yet.
    if [ ! -f "$CA" ]; then
        echo ">>> Generating the mitmproxy CA…"
        timeout 5 mitmdump --listen-port 0 -q >/dev/null 2>&1 || true
    fi
    [ -f "$CA" ] || die "Could not generate the mitmproxy CA (~/.mitmproxy)."
}

case "${1:-gui}" in
  gui)
    # The native Genesi workbench manages the proxy lifecycle itself.
    exec genesi-netinspect-gui
    ;;
  cert)
    ensure_ca
    echo ">>> Trusting the mitmproxy CA system-wide (asks for your password)…"
    sudo install -Dm644 "$CA" "$ANCHOR"
    sudo update-ca-trust
    echo ">>> Done. HTTPS/API traffic through the proxy now decrypts."
    echo "    (Some apps with their own trust store — Firefox, Java — still need"
    echo "     the CA imported separately.)"
    exit 0
    ;;
  untrust)
    echo ">>> Removing the trusted mitmproxy CA (asks for your password)…"
    sudo rm -f "$ANCHOR"
    sudo update-ca-trust
    echo ">>> Removed."
    exit 0
    ;;
  browser)
    ensure_ca
    chrome="$(find_chromium)" || \
        die "No Chromium-family browser found. Install one, e.g.: sudo pacman -S chromium"
    profile="${XDG_DATA_HOME:-$HOME/.local/share}/genesi-netinspect/browser-profile"
    mkdir -p "$profile"
    spki="$(ca_spki || true)"
    args=(
        "--proxy-server=http://$HOST:$PORT"
        "--proxy-bypass-list=<-loopback>"
        "--user-data-dir=$profile"
        --no-first-run --no-default-browser-check --new-window about:blank
    )
    [ -n "$spki" ] && args=("--ignore-certificate-errors-spki-list=$spki" "${args[@]}")
    echo ">>> Opening $chrome pre-configured for the inspector at $HOST:$PORT"
    echo "    (isolated profile, HTTPS trusted via the mitmproxy CA — no system proxy change)"
    if [ -z "$spki" ]; then
        echo "    NOTE: openssl missing — HTTPS sites may warn; run 'genesi-netinspect cert' or accept per-site."
    fi
    exec "$chrome" "${args[@]}"
    ;;
  web|run) ;;
  *) die "usage: genesi-netinspect {gui|web|browser|cert|untrust}" ;;
esac

ensure_ca

cleanup() { GENESI_PROXY_PORT="$PORT" genesi-proxy off >/dev/null 2>&1 || true; }
trap cleanup EXIT INT TERM

# Route the desktop through the inspector for the duration of this session.
GENESI_PROXY_PORT="$PORT" genesi-proxy on >/dev/null 2>&1 || true

echo ">>> Genesi API Inspector (mitmproxy)"
echo "    proxy : $HOST:$PORT        UI: http://$HOST:$WEBPORT"
if ! [ -f "$ANCHOR" ]; then
    echo "    HTTPS not decrypting? Run once:  genesi-netinspect cert"
    echo "    (or open http://mitm.it through the proxy to install the CA per-app)"
fi
echo "    In the UI: pause/intercept + edit a request, inspect it, or replay it."
echo "    Close this window to turn the proxy back off."

exec mitmweb \
    --listen-host "$HOST" --listen-port "$PORT" \
    --web-host "$HOST" --web-port "$WEBPORT" \
    "$@"
