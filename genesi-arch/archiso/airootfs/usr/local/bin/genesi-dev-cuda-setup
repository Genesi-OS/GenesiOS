#!/usr/bin/env bash
#
# Genesi OS — DEV / TEST ONLY (not for end users, never installed to disk).
# Prepares, IN THE LIVE SESSION (RAM overlay), GPU-accelerated local inference so
# you can validate Genesi Turbo (speculative decoding) on the NVIDIA GPU.
#
# Steps (each is best-effort and NON-destructive — a failure never leaves you
# with a broken ollama or no llama-server):
#   1. verify you booted the DEV entry (nouveau blacklisted);
#   2. install the open NVIDIA kernel module (DKMS) for the running kernel + utils;
#   3. load nvidia + nvidia_uvm and verify with nvidia-smi;
#   4. install a GPU llama-server for Turbo. The reliable baseline is the Vulkan
#      build (genesi-llama-cpp): with the proprietary NVIDIA driver loaded it runs
#      on NVIDIA's MATURE Vulkan ICD (not NVK), so speculative decoding behaves.
#      The CUDA build (llama.cpp-cuda, AUR) is attempted as a BEST-EFFORT upgrade
#      — it is a heavy source compile that often will NOT fit a 20G RAM overlay
#      (nvcc/gcc mismatch or out-of-space); if it fails, Turbo stays on Vulkan.
#   5. install ollama-cuda for GPU `ollama` (used by `genesi-ai-mode bench`), with
#      a safe fallback to plain ollama so model pulls always work.
#
# Then TEST from the CLI (this DEV session is a text console, no desktop):
#   genesi-ai-turbo bench qwen2.5:7b        # spec vs no-spec on your GPU
#   genesi-ai-turbo serve qwen2.5:7b --spec # run Turbo with speculative on
#
# Everything lives in RAM and VANISHES on reboot. Run as a NORMAL user (it uses
# sudo where needed; the AUR build must not run as root).
set -uo pipefail

say()  { printf '\n\033[1;32m:: %s\033[0m\n' "$*"; }
warn() { printf '\033[1;33m[!] %s\033[0m\n' "$*"; }
die()  { printf '\033[1;31m[x] %s\033[0m\n' "$*"; exit 1; }

[[ $EUID -eq 0 ]] && warn "Running as root: the CUDA Turbo backend (AUR) will be SKIPPED (makepkg refuses root). Run as a normal user to attempt it."

SUDO=""
[[ $EUID -ne 0 ]] && SUDO="sudo"

say "Genesi DEV/TEST — NVIDIA + CUDA setup (live session, in RAM)"

# 1) nouveau must be blacklisted (the DEV boot entry does this) — otherwise the
#    NVIDIA module can't claim the GPU, and there's no reboot to fix it (the
#    overlay is gone on reboot).
if lsmod | grep -q '^nouveau'; then
    die "nouveau is still loaded. Reboot and pick the 'Genesi OS [DEV/TEST] NVIDIA + CUDA' boot entry (it passes module_blacklist=nouveau)."
fi

# 2) headers for the RUNNING kernel (linux-cachyos vs -lts) so DKMS can build.
KREL="$(uname -r)"
case "$KREL" in
    *-lts*) HEADERS="linux-cachyos-lts-headers" ;;
    *)      HEADERS="linux-cachyos-headers" ;;
esac
say "Running kernel: $KREL  ->  headers: $HEADERS"

say "Refreshing package databases…"
$SUDO pacman -Sy --noconfirm || die "pacman -Sy failed"

say "Installing the open NVIDIA driver (DKMS) + utils… (builds the module, ~1-3 min)"
$SUDO pacman -S --needed --noconfirm dkms "$HEADERS" nvidia-open-dkms nvidia-utils \
    || die "failed to install the NVIDIA driver"

# 3) load the modules (no reboot). nvidia_uvm is what CUDA actually uses.
say "Loading NVIDIA modules…"
$SUDO modprobe nvidia        || die "modprobe nvidia failed (see: dmesg | grep -i nvidia)"
$SUDO modprobe nvidia_uvm    || warn "nvidia_uvm did not load — CUDA may not work"

if ! nvidia-smi; then
    die "nvidia-smi did not respond — the driver did not initialize. See: dmesg | grep -i nvidia"
fi
say "nvidia-smi OK — GPU ready for compute."

# 4) Turbo backend. Try the CUDA build first (best-effort, normal user only);
#    if it doesn't build, fall back to the reliable Vulkan backend so Turbo
#    ALWAYS has a working llama-server. Only ONE can be installed at a time —
#    genesi-llama-cpp and llama.cpp-cuda both provide /usr/bin/llama-server and
#    conflict — so we never keep both.
cuda_ok=0
if [[ $EUID -ne 0 ]] && command -v paru >/dev/null 2>&1; then
    say "Attempting the CUDA llama-server (llama.cpp-cuda, AUR)… heavy compile; may fail in the RAM overlay — Turbo will still work on Vulkan if it does."
    # llama.cpp-cuda needs the CUDA toolkit (nvcc) to compile.
    $SUDO pacman -S --needed --noconfirm cuda \
        || warn "cuda toolkit not installed — the CUDA build will likely fail."
    # Clear the conflicting Vulkan build (if a previous run installed it) so the
    # AUR install isn't blocked by a file/conflict; restored below on failure.
    pacman -Qq genesi-llama-cpp &>/dev/null \
        && $SUDO pacman -Rdd --noconfirm genesi-llama-cpp 2>/dev/null || true
    if paru -S --needed --noconfirm llama.cpp-cuda; then
        cuda_ok=1
        say "CUDA llama-server installed — Turbo will run on CUDA."
    else
        warn "CUDA build failed — Turbo will use the Vulkan backend instead."
    fi
else
    warn "No AUR helper as a normal user (or running as root) — skipping the CUDA build; using the Vulkan backend."
fi

# Guarantee a llama-server exists. If CUDA didn't install one, install the
# Vulkan build (genesi-llama-cpp), which runs on the proprietary NVIDIA Vulkan
# driver now that it's loaded (mature, not NVK).
if ! command -v llama-server >/dev/null 2>&1; then
    say "Installing the Vulkan llama-server (genesi-llama-cpp) — runs on your NVIDIA Vulkan driver."
    $SUDO pacman -S --needed --noconfirm genesi-llama-cpp \
        || die "could not install any llama-server — Turbo has no backend."
fi
if [ "$cuda_ok" = 0 ]; then
    BACKEND="Vulkan (NVIDIA Vulkan driver)"
else
    BACKEND="CUDA"
fi

# 5) ollama for `genesi-ai-mode bench` (Turbo itself reads the GGUF weights
#    directly via llama-server and does NOT need ollama for inference). Prefer
#    the GPU build, but NEVER leave the session with no ollama: if ollama-cuda
#    fails, restore plain ollama. Idempotent: skip the destructive swap if
#    ollama-cuda is already installed (so re-running can't break ollama).
if pacman -Qq ollama-cuda &>/dev/null; then
    say "ollama-cuda already installed."
else
    say "Installing ollama-cuda (GPU ollama; pulls the CUDA runtime, several GB)…"
    # ollama-cuda conflicts with ollama; drop a plain ollama first so the GPU
    # build can install non-interactively.
    had_ollama=0; pacman -Qq ollama &>/dev/null && had_ollama=1
    $SUDO pacman -Rdd --noconfirm ollama 2>/dev/null || true
    if $SUDO pacman -S --needed --noconfirm ollama-cuda; then
        say "ollama-cuda installed."
    else
        warn "ollama-cuda failed — installing plain ollama so model pulls still work."
        $SUDO pacman -S --needed --noconfirm ollama \
            || { [ "$had_ollama" = 1 ] && warn "could not restore ollama either."; }
    fi
fi
$SUDO systemctl enable --now ollama 2>/dev/null || true

cat <<EOF

============================================================
 DONE. Turbo backend: ${BACKEND}

 Test it from the CLI (this DEV session has no desktop):
   genesi-ai-turbo bench qwen2.5:7b         # spec vs no-spec, your GPU
   genesi-ai-turbo serve qwen2.5:7b --spec  # run Turbo with speculative on

 Tip: if the CUDA build failed, the Vulkan backend above still uses your
 NVIDIA GPU (mature Vulkan driver). The CUDA source build is better suited to
 an INSTALLED system than a 20G RAM overlay.

 Reminder: everything here lives in RAM and vanishes on reboot (live DEV).
============================================================
EOF
